# Reddit API credentials (leave blank during dev — MockRedditClient will be used)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=NeepFeed/1.0 (by /u/your_reddit_username)

# Flask
FLASK_ENV=production
FLASK_SECRET_KEY=change-me-in-prod

# Data
DATABASE_PATH=./data/neepfeed.db

# Collection
COLLECTION_INTERVAL_MINUTES=25
# Set to "mock" to force the mock client, "praw" to force real. Auto-detects if unset.
REDDIT_CLIENT_MODE=

# Server
HOST=0.0.0.0
PORT=5000
