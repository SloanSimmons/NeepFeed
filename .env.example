# NeepFeed uses Reddit's public JSON endpoints by default — no API app
# required. You only need the PRAW credentials below if you've been
# approved for a Reddit OAuth app and want to use authenticated access.

# Optional: only used if REDDIT_CLIENT_MODE=praw or all four are present.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Required always (used by the HTTP client too — Reddit throttles blank /
# default User-Agents aggressively). Replace with your Reddit username.
REDDIT_USER_AGENT=NeepFeed/1.0 (self-hosted personal reader; by /u/your_reddit_username)

# Client selection. Blank = auto (HTTP unless PRAW creds detected).
# Explicit values: mock | http | praw
REDDIT_CLIENT_MODE=

# Flask
FLASK_ENV=production

# Data
DATABASE_PATH=./data/neepfeed.db

# Collection
COLLECTION_INTERVAL_MINUTES=25

# Server
HOST=0.0.0.0
PORT=5000
